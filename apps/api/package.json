{
  "name": "@baydar/api",
  "version": "0.0.1",
  "private": true,
  "description": "Baydar NestJS API — REST + SSE + Swagger",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "pnpm --filter @baydar/shared build && pnpm --filter @baydar/db build",
    "build": "nest build",
    "predev": "pnpm --filter @baydar/shared build && pnpm --filter @baydar/db build",
    "dev": "nest start --watch",
    "prestart": "pnpm --filter @baydar/shared build && pnpm --filter @baydar/db build",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "pretest": "pnpm --filter @baydar/shared build && pnpm --filter @baydar/db build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@baydar/db": "workspace:*",
    "@baydar/shared": "workspace:*",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/platform-socket.io": "^10.4.6",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.6",
    "bcrypt": "^5.1.1",
    "blurhash": "^2.0.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "expo-server-sdk": "^6.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@baydar/config": "workspace:*",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.6",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
