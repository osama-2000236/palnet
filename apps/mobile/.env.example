# Mobile env — copy to .env (gitignored) and adjust for your machine.
#
# Expo Go on a physical device hits Metro on the host PC's LAN IP, NOT
# localhost. Use the same LAN IP for the API base URL so the app can
# reach Nest from the phone.
#
# How to find the LAN IP:
#   Windows:  `ipconfig` → IPv4 Address
#   macOS:    `ifconfig | grep 'inet '`
#   Linux:    `ip -4 addr`
#
# Example assumes the laptop is at 192.168.1.2.

EXPO_PUBLIC_API_URL=http://192.168.1.2:4000/api/v1

# Sentry / PostHog stay disabled in Expo Go even when set. Use real keys
# only on dev-client / EAS builds.
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App version — surfaces as Sentry release tag once Sentry is enabled.
# EXPO_PUBLIC_APP_VERSION=0.1.0
