{
  "expo": {
    "name": "PalNet",
    "slug": "palnet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "palnet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ps.palnet.app",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ar-PS",
        "CFBundleLocalizations": ["ar-PS", "en"]
      }
    },
    "android": {
      "package": "ps.palnet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-localization", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
