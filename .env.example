# ──────────────────────────────────────────────────────────────
# Baydar — .env.example
# Copy to .env.local (gitignored). Never commit real secrets.
# Prod values live in Render/Vercel/EAS env panels.
# ──────────────────────────────────────────────────────────────

# Shared
NODE_ENV=development

# ─── Database (Neon) ───
DATABASE_URL=postgresql://user:password@localhost:5432/baydar?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/baydar?schema=public

# ─── API (NestJS) ───
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
CRON_SECRET=change-me-cron-secret-32chars-min
EXPO_ACCESS_TOKEN=

JWT_ACCESS_SECRET=change-me-access-32chars-min
JWT_REFRESH_SECRET=change-me-refresh-32chars-min
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

BCRYPT_COST=12
REDIS_URL=
EMAIL_VERIFY_URL_BASE=http://localhost:3000/verify-email
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
EMAIL_VERIFY_MOBILE_URL_BASE=baydar://auth/verify
PASSWORD_RESET_MOBILE_URL_BASE=baydar://auth/reset

# ─── OAuth (Sprint 1.5) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# ─── Transactional email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM=noreply@baydar.app

# ─── Cloudflare R2 (S3-compatible) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=baydar-media-dev
R2_PUBLIC_URL=https://media.baydar.ps

# ─── Web (Next.js) ───
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Deprecated: web derives SSE endpoints from NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=ar-PS

# ─── Mobile (Expo) ───
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WEB_URL=http://localhost:3000
# Deprecated: mobile derives SSE endpoints from EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_WS_URL=http://localhost:4000
EXPO_PUBLIC_DEFAULT_LOCALE=ar-PS
