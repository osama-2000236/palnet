{
  "name": "palnet",
  "version": "0.0.1",
  "private": true,
  "description": "Palestine-first professional network. LinkedIn-equivalent scope, day-one pragmatic stack.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "node scripts/run-turbo.mjs build",
    "dev": "node scripts/run-turbo.mjs dev --parallel",
    "lint": "node scripts/run-turbo.mjs lint",
    "i18n:parity": "node scripts/i18n-parity.mjs",
    "lint:tokens": "node scripts/lint-tokens.mjs",
    "tokens:icons": "node scripts/build-brand-icons.mjs",
    "test": "node scripts/run-turbo.mjs test",
    "type-check": "node scripts/run-turbo.mjs type-check",
    "clean": "node scripts/run-turbo.mjs clean && rimraf node_modules",
    "format": "prettier --write --ignore-unknown \"**/*.{ts,tsx,js,json,md,prisma}\"",
    "format:check": "prettier --check --ignore-unknown \"**/*.{ts,tsx,js,json,md,prisma}\"",
    "db:generate": "corepack pnpm --filter @palnet/db db:generate",
    "db:migrate": "corepack pnpm --filter @palnet/db db:migrate",
    "db:deploy": "corepack pnpm --filter @palnet/db db:deploy",
    "db:studio": "corepack pnpm --filter @palnet/db db:studio",
    "db:seed": "corepack pnpm --filter @palnet/db db:seed",
    "qa:web-authed": "node scripts/qa-web-authed.mjs"
  },
  "devDependencies": {
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "turbo": "^2.2.0",
    "typescript": "^5.6.0"
  }
}
